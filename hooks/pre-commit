#!/bin/sh
# Auto-increment build number before every commit.

PYTHON=""
for cmd in python3 python py; do
    if command -v "$cmd" > /dev/null 2>&1; then
        PYTHON="$cmd"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    echo "pre-commit: Python not found — build number NOT incremented" >&2
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

$PYTHON - "$REPO_ROOT" <<'PYEOF'
import re, sys
from pathlib import Path

root  = Path(sys.argv[1])
vfile = root / "VERSION"
gui   = root / "kis_search_gui.py"

if not vfile.exists():
    sys.exit(0)

text  = vfile.read_text()
major = re.search(r"MAJOR=(\d+)", text).group(1)
build = int(re.search(r"BUILD=(\d+)", text).group(1))
new_b = f"{build + 1:04d}"

vfile.write_text(f"MAJOR={major}\nBUILD={new_b}\n")

content = gui.read_text(encoding="utf-8")
content = re.sub(
    r'(_VERSION_BUILD\s*=\s*)"[0-9]+"',
    rf'\g<1>"{new_b}"',
    content,
)
gui.write_text(content, encoding="utf-8")

print(f"pre-commit: version {major}.{new_b}")
PYEOF

git add VERSION kis_search_gui.py
